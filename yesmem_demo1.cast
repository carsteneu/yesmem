[110.656459, "o", "\u001b[?2026h\r\u001b[10A  \u001b[1mFix:\u001b[22m \u001b[38;2;177;185;249msession-end\u001b[39m routet jetzt über den Daemon-Socket (RPC) statt direkt in die DB zu schreiben. Neuer Handler \u001b[38;2;177;185;249mhandleTrackSessionEnd\u001b[39m in              \r\u001b[1B  \u001b[38;2;177;185;249mhandler_state.go\u001b[39m.\u001b[1C\u001b[1m58ms statt 7200ms.\u001b[1C\u001b[22mDeployed\u001b[1Cund\u001b[1CE2E-verifiziert.\r\u001b[1B                                                                                                                                                      \r\u001b[1B\u001b[38;2;136;136;136m──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[1B\u001b[38;2;153;153;153m❯ \u001b[39m                                                                                  \r\u001b[1B\u001b[38;2;136;136;136m──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[2C\u001b[1B\u001b[32m\u001b[1mchief@chieftp32\u001b[22m\u001b[38;2;153;153;153m:\u001b[34m\u001b[1m/home/chief/memory/yesmem\u001b[22m\u001b[39m                 \r\u001b[2C\u001b[1B\u001b[32m\u001b[1mCacheLifeTime (5min) until 15:12 | Keepalive until 15:39 with 6 ping(s) every 4min\r\u001b[2C\u001b[1B\u001b[22m\u001b[37mLossless collapsing at 200k to 60k Token | actual usage: 79k / 200k Token\r\u001b[2C\u001b[1BR: 55k  W: 5k  U: 0k  (91% hit)  last input request: \u001b[32m\u001b[1m$0.06\u001b[22m\u001b[39m\r\r\n\u001b[2C\u001b[91mafter\u001b[1CCache\u001b[1Cexpiry\u001b[1C$0.49\u001b[1Cfor\u001b[1Crefresh\u001b[39m\r\r\n\u001b[2C\u001b[36mSessionId:\u001b[1Cfabf88d3-048c-45de-a686-953192ee7093\u001b[39m\r\r\n\u001b[2C\u001b[38;2;175;135;255m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;2;153;153;153m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[39m\r\r\n\u001b[?2026l"]
[111.734943, "o", "\u001b[?2026h\r\u001b[10A  \u001b[1mDazu kamen ~30 Commits\u001b[22m an dem Tag, u.a.:                                                                                                            \r\u001b[1B  \r\u001b[1B  ┌────────┬─────┐                                                                                                                                    \r\u001b[2C\u001b[1B│ Commit │ Was │                         \r\u001b[2C\u001b[1B├────────┼─────┤                                                                  \r\u001b[2C\u001b[1B└────────┴─────┘                                                         \r\u001b[2C\u001b[1B                                                          \r\u001b[1B\u001b[38;2;136;136;136m──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[1B\u001b[38;2;153;153;153m❯ \u001b[39m                                               \r\u001b[1B\u001b[38;2;136;136;136m──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\n\u001b[2C\u001b[32m\u001b[1mchief@chieftp32\u001b[22m\u001b[38;2;153;153;153m:\u001b[34m\u001b[1m/home/chief/memory/yesmem\u001b[22m\u001b[39m\r\r\n\u001b[2C\u001b[32m\u001b[1mCacheLifeTime\u001b[1C(5min)\u001b[1Cuntil\u001b[1C15:12\u001b[1C|\u001b[1CKeepalive\u001b[1Cuntil\u001b[1C15:39\u001b[1Cwith\u001b[1C6\u001b[1Cping(s)\u001b[1Cevery\u001b[1C4min\u001b[22m\u001b[39m\r\r\n\u001b[2C\u001b[37mLossless\u001b[1Ccollapsing\u001b[1Cat\u001b[1C200k\u001b[1Cto\u001b[1C60k\u001b[1CToken\u001b[1C|\u001b[1Cactual\u001b[1Cusage:\u001b[1C79k\u001b[1C/\u001b[1C200k\u001b[1CToken\u001b[39m\r\r\n\u001b[2C\u001b[37mR:\u001b[1C55k\u001b[2CW:\u001b[1C5k\u001b[2CU:\u001b[1C0k\u001b[2C(91%\u001b[1Chit)\u001b[2Clast\u001b[1Cinput\u001b[1Crequest:\u001b[1C\u001b[32m\u001b[1m$0.06\u001b[22m\u001b[39m\r\r\n\